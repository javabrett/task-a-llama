# task-a-llama — runtime secrets and local config
#
# Copy this file to .env and fill in real values.
# .env is gitignored; never commit real secrets.

# --- Vikunja service config ---

# Service secret — signs JWT session tokens (env key: VIKUNJA_SERVICE_SECRET).
# Generate with: openssl rand -base64 32
# Changing this invalidates all existing sessions.
VIKUNJA_JWT_SECRET=generate_with_openssl_rand_base64_32

# Public URL Vikunja believes it's reachable at.
# For localhost-only deployment, keep as below.
# Test instance: http://localhost:4567/
VIKUNJA_SERVICE_PUBLICURL=http://localhost:3456/

# Host port to bind on. Production default 3456; test instance uses 4567.
VIKUNJA_PORT=3456

# Container names. Each instance must have unique container names so
# production and test can run side-by-side.
# Test instance: VIKUNJA_CONTAINER_NAME=vikunja-test, VIKUNJA_WATCHTOWER_NAME=task-a-llama-watchtower-test
VIKUNJA_CONTAINER_NAME=vikunja
VIKUNJA_WATCHTOWER_NAME=task-a-llama-watchtower

# Registration toggle. Keep false.
# bootstrap.sh creates the initial account via the Vikunja CLI (docker exec),
# so registration never needs to be enabled. Additional users can be created
# the same way: docker exec vikunja /app/vikunja/vikunja user create ...
VIKUNJA_SERVICE_ENABLEREGISTRATION=false

# Timezone — affects reminder delivery and timestamp display.
# Use official tz database names (e.g. Australia/Sydney, Europe/London).
TZ=Australia/Sydney

# Task identifier display format (requires Vikunja fork feat/configurable-task-identifier-display).
# Supported placeholders: {identifier}, {id}, {index}, {prefix}
# Quote values containing '#' to prevent Docker Compose treating it as a comment.
# Default (omit to use upstream behaviour): {identifier}
# Recommended with global ID exposed: "{identifier} (ID #{id})"
#VIKUNJA_SERVICE_TASKIDENTIFIERDISPLAY="{identifier} (ID #{id})"

# --- Claude Code integration ---

# Base URL the /tal skill uses to reach the API.
# Production: http://localhost:3456/api/v1
# Test:       http://localhost:4567/api/v1
VIKUNJA_BASE_URL=http://localhost:3456/api/v1

# Vikunja API token for Claude Code to authenticate against the API.
# Create in Vikunja UI: Settings → API Tokens → Create.
# Scope minimally to what Claude Code actually needs.
VIKUNJA_API_TOKEN=create_in_vikunja_ui_after_first_login
